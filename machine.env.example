# Copy to machine.env and fill in. machine.env is gitignored — keys never leave this box.

# Which queue adapter: blotato | postiz
QUEUE_ADAPTER=blotato

# ---- Blotato ----
# File containing the Blotato key (any line mentioning 'blotato', value after = or :)
BLOTATO_KEY_FILE="$HOME/Desktop/GitSync/kloop.env"
# Account IDs — run: adapters/blotato.sh accounts
BLOTATO_ACCOUNT_X=
BLOTATO_ACCOUNT_INSTAGRAM=
BLOTATO_ACCOUNT_TIKTOK=
BLOTATO_ACCOUNT_FACEBOOK=
BLOTATO_FACEBOOK_PAGE_ID=
BLOTATO_ACCOUNT_YOUTUBE=
BLOTATO_ACCOUNT_LINKEDIN=

# ---- Postiz (self-hosted; true drafts) ----
POSTIZ_API_URL=http://localhost:3000/api
POSTIZ_API_KEY=

# ---- Defaults ----
DEFAULT_CHANNELS=x
